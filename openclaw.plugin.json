{
  "id": "line-exec-approval-plugin",
  "name": "LINE Exec Approval Plugin",
  "description": "Sends exec approval requests to LINE as interactive Flex Message cards with approve/deny buttons.",
  "version": "0.3.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "lineUserId": {
        "type": "string"
      },
      "channelAccessToken": {
        "type": "string"
      },
      "channelAccessTokenFile": {
        "type": "string"
      },
      "channelAccessTokenEnv": {
        "type": "string"
      },
      "buttonAction": {
        "type": "string",
        "enum": [
          "command",
          "friendly",
          "silent"
        ],
        "description": "command=shows raw /approve text, friendly=shows label, silent=nothing in chat"
      }
    }
  }
}