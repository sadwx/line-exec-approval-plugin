{
  "id": "line-exec-approval-plugin",
  "name": "LINE Exec Approval Plugin",
  "description": "Sends exec approval requests to LINE as interactive Flex Message cards with approve/deny buttons.",
  "version": "0.1.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "lineUserId": {
        "type": "string"
      },
      "channelAccessToken": {
        "type": "string"
      },
      "channelAccessTokenFile": {
        "type": "string"
      },
      "channelAccessTokenEnv": {
        "type": "string"
      }
    }
  }
}